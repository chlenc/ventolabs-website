# Copy to .env.local for local dev overrides (e.g. a separate PostHog
# project for testing). For production, .env.production is committed
# with the real project token — NEXT_PUBLIC_* values end up in the
# client bundle anyway, so they aren't secrets.

NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Copy to .env.local and fill in real values for local development.
# In production these are injected by the GitHub Actions deploy workflow
# from repo secrets.

# PostHog product analytics — create a project at https://us.posthog.com
# and paste the Project API key (starts with "phc_"). Write-only, safe
# to expose in client bundles.
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Region host. US: https://us.i.posthog.com  |  EU: https://eu.i.posthog.com
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
